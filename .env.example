# ============================================================
# VitalCowork — Variables de entorno
# Copia este archivo a .env.local y completa los valores.
# ============================================================

# ---------- Supabase (obligatorio) ----------
# Crea un proyecto en https://supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon...
# Service role: SOLO en el servidor (Vercel → Environment Variables). Nunca en el cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role...

# ---------- Payphone (pasarela de tarjetas, https://docs.payphone.app) ----------
# 1. Crea tu cuenta de comercio en Payphone Business
# 2. En la consola de desarrolladores crea una aplicación tipo "Botón de pagos"
# 3. Copia el Token y el StoreId aquí
PAYPHONE_TOKEN=
PAYPHONE_STORE_ID=

# ---------- Notificaciones push (Web Push / VAPID) ----------
# Genera las llaves con:  npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=admin@vitalcowork.ec

# ---------- Correo transaccional (Resend, https://resend.com — plan gratuito) ----------
# Sin esta clave los correos se omiten (solo se registra en logs)
RESEND_API_KEY=
EMAIL_FROM="VitalCowork <notificaciones@tudominio.com>"

# ---------- Cron de recordatorios/expiraciones ----------
# Inventa una clave larga; el cron externo llama:
#   GET https://TU-APP.vercel.app/api/cron/tareas?clave=ESTE_VALOR
CRON_SECRET=

# ---------- Solo para el test de concurrencia (desarrollo local) ----------
# TEST_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
